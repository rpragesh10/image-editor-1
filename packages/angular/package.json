{
  "name": "@rageshpikalmunde/rp-image-editor-angular",
  "version": "1.1.0",
  "description": "Angular wrapper for rp-image-editor — use inside Ionic+Angular apps",
  "main": "dist/cjs/index.js",
  "module": "dist/esm/index.js",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js",
      "types": "./dist/types/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "npm run build:esm && npm run build:cjs && npm run build:types",
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build:types": "tsc -p tsconfig.types.json",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "image-editor",
    "angular",
    "ionic",
    "capacitor"
  ],
  "author": "Ragesh Pikalmunde",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@rageshpikalmunde/rp-image-editor": "^1.1.0"
  },
  "peerDependencies": {
    "@angular/core": ">=14.0.0",
    "@angular/common": ">=14.0.0",
    "@ionic/angular": ">=6.0.0"
  },
  "devDependencies": {
    "typescript": "~5.3.0"
  }
}
